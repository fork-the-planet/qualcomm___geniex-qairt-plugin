{
    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/geniex-app/include",
                "${workspaceFolder}/geniex-app/src",
                "${workspaceFolder}/geniex-app/src/qnn-api",
                "${workspaceFolder}/models/**",
                "${workspaceFolder}/third-party/**",
                "${workspaceFolder}/third-party/geniex-proc/include"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE",
                "_WIN32",
                "_WINDOWS"
            ],
            "windowsSdkVersion": "10.0.19041.0",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "windows-msvc-arm64",
            "compileCommands": "${workspaceFolder}/compile_commands.json",
            "configurationProvider": "ms-vscode.cmake-tools"
        }
    ],
    "version": 4
}